{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": ["<rootDir>/e2e-env.ts"],
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^generated/prisma$": "<rootDir>/../generated/prisma"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
