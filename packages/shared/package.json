{
  "name": "@chess-db/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --format cjs,esm --dts",
    "dev": "tsdown src/index.ts --format cjs,esm --watch --dts"
  },
  "devDependencies": {
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3"
  }
}
